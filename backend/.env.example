# ============================================
# .env.example — Environment Variables Template
# ============================================
# Copy this file as ".env" and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit your .env file to Git (it contains secrets!)

# Server port
PORT=5000

# MongoDB connection string
# For local MongoDB:
MONGO_URI=mongodb://localhost:27017/hotel_management
# For Docker:
# MONGO_URI=mongodb://mongo:27017/hotel_management

# JWT secret key (use a long random string in production)
JWT_SECRET=your_jwt_secret_key_change_this

# JWT token expiration
JWT_EXPIRE=7d
